{
  "name": "proto",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/proto/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "proto-gen": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{workspaceRoot}/proto/**/*.proto"],
      "outputs": ["{workspaceRoot}/libs/proto/src/gen/**"],
      "options": {
        "command": "mkdir -p libs/proto/src/gen && node_modules/.bin/buf generate",
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "dependsOn": ["proto-gen"],
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/proto",
        "main": "libs/proto/src/index.ts",
        "tsConfig": "libs/proto/tsconfig.lib.json",
        "assets": ["libs/proto/*.md"]
      }
    }
  }
}
